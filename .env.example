# LLM Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_BASE_URL=http://localhost:11434/v1

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=sales-agent

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sales_agent

# Google Calendar
# Path to the Google Service Account JSON credentials file.
GOOGLE_SERVICE_ACCOUNT_JSON=sales_agent.json

# Google Calendar ID for the tenant (e.g. your_calendar@group.calendar.google.com)
GOOGLE_CALENDAR_ID=

# Email (SMTP / SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=

# Verified sender email
FROM_EMAIL=no-reply@yourcompany.com